{
	"name": "Waitlist",
	"scripts": {
		"dev": "concurrently --names \"SERVER,CLIENT\" \"bun run server\" \"bun run client\"",
		"server": "bun run --hot server/index.ts",
		"client": "cd client && bun run dev",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bunx drizzle-kit migrate",
		"db": "bunx drizzle-kit push"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.25",
		"nodemailer": "^8.0.10"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@libsql/client": "^0.17.3",
		"@types/bun": "^1.3.14",
		"@types/nodemailer": "^8.0.0",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10"
	}
}
